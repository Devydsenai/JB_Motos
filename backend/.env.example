# Supabase — copie para .env e preencha com os dados do projeto (Dashboard > Connect)

# Runtime da aplicação (pooler, porta 6543) — use com Prisma Client + adapter
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations e CLI do Prisma (sessão direta, porta 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"

# Opcional — Supabase (auth, storage, realtime no futuro)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="sua-anon-key"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
