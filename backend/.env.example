# ============================================================
# JB MOTOS — Variáveis de Ambiente
# ============================================================

# Supabase PostgreSQL
# Porta 6543 (pooler) para runtime — Prisma Client
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Porta 5432 (direto) para migrations — prisma migrate
DIRECT_URL="postgresql://postgres.[project]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Server (Render injeta PORT automaticamente — não precisa fixar 3001 lá)
PORT=3001
NODE_ENV=development

# JWT — mínimo 32 caracteres, aleatório
JWT_SECRET=troque_por_uma_chave_secreta_forte_minimo_32_chars
JWT_EXPIRES_IN=8h

# CORS — inclua TODAS as URLs do frontend (separadas por vírgula, sem espaço extra)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://jbmotosr.netlify.app,https://jbmotosj.netlify.app

# Mercado Pago — credencial de TESTE em developers.mercadopago.com (conta de teste)
MERCADO_PAGO_ACCESS_TOKEN=TEST-seu_access_token_de_teste
# Sandbox: cartão/PIX fictícios (padrão true em development)
MERCADO_PAGO_SANDBOX=true

# URLs — produção (Render) — obrigatório configurar no painel do Render
# FRONTEND_URL=https://jbmotosr.netlify.app
# API_PUBLIC_URL=https://jb-motos-api.onrender.com
# ALLOWED_ORIGINS=https://jbmotosj.netlify.app,http://localhost:5173

# URLs locais
FRONTEND_URL=http://localhost:5173

# Assistentes n8n (proxy /api/v1/assistants/* — use no Render em produção)
N8N_CLIENT_ASSISTANT_URL=https://devyds.app.n8n.cloud/webhook/jb-motos/assistente-cliente
N8N_ADMIN_ASSISTANT_URL=https://devyds.app.n8n.cloud/webhook/jb-motos/assistente-administrativo
