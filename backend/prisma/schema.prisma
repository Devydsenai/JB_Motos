generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Tabela de teste — validar Prisma + Supabase antes da equipe criar o schema completo
model Teste {
  id        Int      @id @default(autoincrement())
  nome      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("teste")
}
