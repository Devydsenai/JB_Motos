# ============================================================
# JB MOTOS — Variáveis de Ambiente
# ============================================================

# Supabase PostgreSQL
# Porta 6543 (pooler) para runtime — Prisma Client
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Porta 5432 (direto) para migrations — prisma migrate
DIRECT_URL="postgresql://postgres.[project]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Server
PORT=3001
NODE_ENV=development

# JWT — mínimo 32 caracteres, aleatório
JWT_SECRET=troque_por_uma_chave_secreta_forte_minimo_32_chars
JWT_EXPIRES_IN=8h

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
